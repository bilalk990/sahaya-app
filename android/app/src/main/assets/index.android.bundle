97\u0ca6\u0cc1.',reasonPlaceholder:'\u0c88 \u0c85\u0caa\u0ccd \u0ca8\u0ca8\u0c97\u0cc6 \u0c89\u0caa\u0caf\u0cc1\u0c95\u0ccd\u0ca4\u0cb5\u0cb2\u0ccd\u0cb2',reasonPrivacy:'\u0ca8\u0ca8\u0c97\u0cc6 \u0c97\u0ccc\u0caa\u0ccd\u0caf\u0ca4\u0cc6 \u0c86\u0ca4\u0c82\u0c95\u0c97\u0cb3\u0cbf\u0cb5\u0cc6',reasonTooManyNotifications:'\u0ca8\u0ca8\u0c97\u0cc6 \u0cb9\u0cc6\u0c9a\u0ccd\u0c9a\u0cc1 \u0c85\u0ca7\u0cbf\u0cb8\u0cc2\u0c9a\u0ca8\u0cc6\u0c97\u0cb3\u0cc1 \u0cac\u0cb0\u0cc1\u0ca4\u0ccd\u0ca4\u0cbf\u0cb5\u0cc6',reasonDuplicate:'\u0ca8\u0cbe\u0ca8\u0cc1 \u0ca1\u0cc1\u0caa\u0ccd\u0cb2\u0cbf\u0c95\u0cc7\u0c9f\u0ccd \u0c96\u0cbe\u0ca4\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb0\u0c9a\u0cbf\u0cb8\u0cbf\u0ca6\u0ccd\u0ca6\u0cc7\u0ca8\u0cc6',reasonOther:'\u0c87\u0ca4\u0cb0\u0cc6',reasonOtherPlaceholder:'\u0ca8\u0cae\u0cc2\u0ca6\u0cbf\u0cb8\u0cbf',deleteButton:'\u0c96\u0cbe\u0ca4\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca1\u0cbf\u0cb2\u0cc0\u0c9f\u0ccd \u0cae\u0cbe\u0ca1\u0cbf',cancelButton:'\u0cb0\u0ca6\u0ccd\u0ca6\u0cc1\u0cae\u0cbe\u0ca1\u0cbf',confirmTitle:'\u0ca8\u0cc0\u0cb5\u0cc1 \u0c96\u0c9a\u0cbf\u0ca4\u0cb0\u0cbe\u0c97\u0cbf\u0ca6\u0ccd\u0ca6\u0cc0\u0cb0\u0cbe?',confirmDesc:'\u0c88 \u0c95\u0ccd\u0cb0\u0cbf\u0caf\u0cc6 \u0cb8\u0ccd\u0ca5\u0cbf\u0cb0\u0cb5\u0cbe\u0c97\u0cbf\u0cb0\u0cc1\u0ca4\u0ccd\u0ca4\u0ca6\u0cc6. \u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0c8e\u0cb2\u0ccd\u0cb2 \u0ca1\u0cc7\u0c9f\u0cbe \u0cae\u0cc1\u0c9a\u0ccd\u0c9a\u0cb2\u0ccd\u0caa\u0ca1\u0cc1\u0ca4\u0ccd\u0ca4\u0ca6\u0cc6.',confirmCancel:'\u0c87\u0cb2\u0ccd\u0cb2, \u0ca8\u0ca8\u0ccd\u0ca8 \u0c96\u0cbe\u0ca4\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0c87\u0cb0\u0cbf\u0cb8\u0cbf',confirmDelete:'\u0cb9\u0ccc\u0ca6\u0cc1, \u0ca1\u0cbf\u0cb2\u0cc0\u0c9f\u0ccd \u0cae\u0cbe\u0ca1\u0cbf',suport_title:'\u0caa\u0ccd\u0cb0\u0cb6\u0ccd\u0ca8\u0cc6\u0c97\u0cb3\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0caa\u0ccd\u0cb0\u0ca4\u0cbf\u0c95\u0ccd\u0cb0\u0cbf\u0caf\u0cc6\u0c97\u0cb3\u0cbf\u0cb5\u0cc6\u0caf\u0cc7?',suport_subtitle:'\u0ca8\u0cbf\u0cae\u0c97\u0cc6 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0caa\u0ccd\u0cb0\u0cb6\u0ccd\u0ca8\u0cc6\u0c97\u0cb3\u0cc1, \u0caa\u0ccd\u0cb0\u0ca4\u0cbf\u0c95\u0ccd\u0cb0\u0cbf\u0caf\u0cc6\u0c97\u0cb3\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0ca8\u0cae\u0ccd\u0cae\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb8\u0cc1\u0ca7\u0cbe\u0cb0\u0cbf\u0cb8\u0cb2\u0cc1 \u0cb8\u0cb2\u0cb9\u0cc6\u0c97\u0cb3\u0cbf\u0cb5\u0cc6\u0caf\u0cbe\u0ca6\u0cb0\u0cc6, \u0cb8\u0c82\u0caa\u0cb0\u0ccd\u0c95\u0cbf\u0cb8\u0cb2\u0cc1 \u0cb9\u0cbf\u0c82\u0c9c\u0cb0\u0cbf\u0caf\u0cac\u0cc7\u0ca1\u0cbf. \u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0c86\u0cb2\u0ccb\u0c9a\u0ca8\u0cc6\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cbe\u0cb5\u0cc1 \u0c97\u0ccc\u0cb0\u0cb5\u0cbf\u0cb8\u0cc1\u0ca4\u0ccd\u0ca4\u0cc7\u0cb5\u0cc6 \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0cb0\u0cbf\u0cae\u0cc8\u0c82\u0ca1\u0ccd\u200c\u0ca8\u0ccc \u0c85\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cbf\u0cae\u0c97\u0cbe\u0c97\u0cbf \u0cb9\u0cc7\u0c97\u0cc6 \u0cb8\u0cc1\u0ca7\u0cbe\u0cb0\u0cbf\u0cb8\u0cac\u0cb9\u0cc1\u0ca6\u0cc1 \u0c8e\u0c82\u0ca6\u0cc1 \u0ca4\u0cbf\u0cb3\u0cbf\u0caf\u0cb2\u0cc1 \u0c95\u0ccb\u0cb0\u0cbf\u0c95\u0cc6\u0caa\u0ca1\u0cc1\u0ca4\u0ccd\u0ca4\u0cc7\u0cb5\u0cc6. \u0c92\u0c82\u0ca6\u0cc1 \u0c87\u0cae\u0cc7\u0cb2\u0ccd \u0c95\u0cb3\u0cc1\u0cb9\u0cbf\u0cb8\u0cbf \u2014 \u0ca8\u0cbe\u0cb5\u0cc1 \u0caf\u0cbe\u0cb5\u0cbe\u0c97\u0cb2\u0cc2 \u0c95\u0cc7\u0cb3\u0cc1\u0ca4\u0ccd\u0ca4\u0cbf\u0ca6\u0ccd\u0ca6\u0cc7\u0cb5\u0cc6.'},DeleteAccount:{title:'\u0c96\u0cbe\u0ca4\u0cc6 \u0ca1\u0cbf\u0cb2\u0cc0\u0c9f\u0ccd',subtitle:'\u0ca8\u0cc0\u0cb5\u0cc1 \u0cb9\u0ccb\u0c97\u0cc1\u0ca4\u0ccd\u0ca4\u0cbf\u0cb0\u0cc1\u0cb5\u0cc1\u0ca6\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0ccb\u0ca1\u0cbf \u0ca8\u0cbe\u0cb5\u0cc1 \u0cb5\u0cbf\u0cb7\u0cbe\u0ca6\u0cbf\u0cb8\u0cc1\u0ca4\u0ccd\u0ca4\u0cc7\u0cb5\u0cc6.',reason_label:'\u0cb9\u0ccb\u0c97\u0cc1\u0cb5\u0cc1\u0ca6\u0c95\u0ccd\u0c95\u0cc6 \u0c95\u0cbe\u0cb0\u0ca3',placeholder:'\u0ca8\u0cae\u0cc2\u0ca6\u0cbf\u0cb8\u0cbf',delete_btn:'\u0c96\u0cbe\u0ca4\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca1\u0cbf\u0cb2\u0cc0\u0c9f\u0ccd \u0cae\u0cbe\u0ca1\u0cbf',cancel_btn:'\u0cb0\u0ca6\u0ccd\u0ca6\u0cc1\u0cae\u0cbe\u0ca1\u0cbf',confirm_title:'\u0ca8\u0cc0\u0cb5\u0cc1 \u0c96\u0c9a\u0cbf\u0ca4\u0cb0\u0cbe\u0c97\u0cbf\u0ca6\u0ccd\u0ca6\u0cc0\u0cb0\u0cbe?',confirm_desc:'\u0c88 \u0c95\u0ccd\u0cb0\u0cbf\u0caf\u0cc6 \u0cb8\u0ccd\u0ca5\u0cbf\u0cb0\u0cb5\u0cbe\u0c97\u0cbf\u0cb0\u0cc1\u0ca4\u0ccd\u0ca4\u0ca6\u0cc6. \u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0c8e\u0cb2\u0ccd\u0cb2 \u0ca1\u0cc7\u0c9f\u0cbe \u0cae\u0cc1\u0c9a\u0ccd\u0c9a\u0cb2\u0ccd\u0caa\u0ca1\u0cc1\u0ca4\u0ccd\u0ca4\u0ca6\u0cc6.',keep_account:'\u0c87\u0cb2\u0ccd\u0cb2, \u0ca8\u0ca8\u0ccd\u0ca8 \u0c96\u0cbe\u0ca4\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0c87\u0cb0\u0cbf\u0cb8\u0cbf',yes_delete:'\u0cb9\u0ccc\u0ca6\u0cc1, \u0ca1\u0cbf\u0cb2\u0cc0\u0c9f\u0ccd \u0cae\u0cbe\u0ca1\u0cbf'},Festivals:{title:'\u0c89\u0ca4\u0ccd\u0cb8\u0cb5\u0c97\u0cb3\u0cc1',month:'\u0c9c\u0cc1\u0cb2\u0cc8 2023',know_more:'\u0cb9\u0cc6\u0c9a\u0ccd\u0c9a\u0cbf\u0ca8 \u0cae\u0cbe\u0cb9\u0cbf\u0ca4\u0cbf',no_festivals:'\u0c88 \u0ca4\u0cbf\u0c82\u0c97\u0cb3\u0cbf\u0c97\u0cc6 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0c89\u0ca4\u0ccd\u0cb8\u0cb5\u0c97\u0cb3\u0cc1 \u0c95\u0c82\u0ca1\u0cc1\u0cac\u0c82\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2.',upcoming_festivals:'\u0cac\u0cb0\u0cc1\u0cb5 \u0c89\u0ca4\u0ccd\u0cb8\u0cb5\u0c97\u0cb3\u0cc1'},Temple:{Temple:'\u0ca6\u0cc7\u0cb5\u0cbe\u0cb2\u0caf'},Auth:{login:'\u0cb2\u0cbe\u0c97\u0cbf\u0ca8\u0ccd',signup:'\u0cb8\u0cc8\u0ca8\u0ccd \u0c85\u0caa\u0ccd',enter_mobile:'\u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0cae\u0cca\u0cac\u0cc8\u0cb2\u0ccd \u0cb8\u0c82\u0c96\u0ccd\u0caf\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cae\u0cc2\u0ca6\u0cbf\u0cb8\u0cbf',mobile_placeholder:'\u0cae\u0cca\u0cac\u0cc8\u0cb2\u0ccd \u0cb8\u0c82\u0c96\u0ccd\u0caf\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cae\u0cc2\u0ca6\u0cbf\u0cb8\u0cbf',otp_message:'\u0c88 \u0cb8\u0c82\u0c96\u0ccd\u0caf\u0cc6\u0c97\u0cc6 \u0c92\u0c82\u0ca6\u0cc1