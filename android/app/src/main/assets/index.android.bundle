 \u0d15\u0d23\u0d4d\u0d1f\u0d46\u0d24\u0d4d\u0d24\u0d41\u0d15',Filter_Options:'\u0d2b\u0d3f\u0d7d\u0d1f\u0d4d\u0d1f\u0d7c \u0d13\u0d2a\u0d4d\u0d37\u0d28\u0d41\u0d15\u0d7e',Job_Role:'\u0d1c\u0d4b\u0d2c\u0d4d \u0d31\u0d4b\u0d7e',Experience:'\u0d05\u0d28\u0d41\u0d2d\u0d35\u0d02',Region:'\u0d2a\u0d4d\u0d30\u0d26\u0d47\u0d36\u0d02',Area_Pincode:'\u0d2a\u0d4d\u0d30\u0d26\u0d47\u0d36\u0d02/\u0d2a\u0d3f\u0d7b\u0d15\u0d4b\u0d21\u0d4d',Verification:'\u0d35\u0d46\u0d30\u0d3f\u0d2b\u0d3f\u0d15\u0d4d\u0d15\u0d47\u0d37\u0d7b',Gender:'\u0d1c\u0d46\u0d7b\u0d21\u0d7c',Age_Range:'\u0d0f\u0d1c\u0d4d \u0d31\u0d47\u0d1e\u0d4d\u0d1a\u0d4d',Expected_Salary:'\u0d0e\u0d15\u0d4d\u0d38\u0d4d\u0d2a\u0d46\u0d15\u0d4d\u0d31\u0d4d\u0d31\u0d21\u0d4d \u0d38\u0d3e\u0d32\u0d31\u0d3f',Reset_Filters:'\u0d2b\u0d3f\u0d7d\u0d1f\u0d4d\u0d1f\u0d31\u0d41\u0d15\u0d7e \u0d31\u0d40\u0d38\u0d46\u0d31\u0d4d\u0d31\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',Apply_Filters:'\u0d2b\u0d3f\u0d7d\u0d1f\u0d4d\u0d1f\u0d31\u0d41\u0d15\u0d7e \u0d05\u0d2a\u0d4d\u0d32\u0d48 \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',Matching_Candidates:'\u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d2a\u0d4d\u0d30\u0d26\u0d47\u0d36\u0d24\u0d4d\u0d24\u0d46 \u0d2e\u0d3e\u0d1a\u0d4d\u0d1a\u0d3f\u0d02\u0d17\u0d4d \u0d15\u0d3e\u0d7b\u0d21\u0d3f\u0d21\u0d47\u0d31\u0d4d\u0d31\u0d41\u0d15\u0d7e',Contact:'\u0d15\u0d4b\u0d7a\u0d1f\u0d3e\u0d15\u0d4d\u0d1f\u0d4d',Police_Verification:'\u0d2a\u0d4b\u0d32\u0d40\u0d38\u0d4d \u0d35\u0d46\u0d30\u0d3f\u0d2b\u0d3f\u0d15\u0d4d\u0d15\u0d47\u0d37\u0d7b',Verified:'\u0d35\u0d46\u0d30\u0d3f\u0d2b\u0d48\u0d21\u0d4d',Unverified:'\u0d05\u0d7a\u0d35\u0d46\u0d30\u0d3f\u0d2b\u0d48\u0d21\u0d4d'},FindStaffAI:{title:'AI\u0d2f\u0d4b\u0d1f\u0d4a\u0d2a\u0d4d\u0d2a\u0d02 \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d15\u0d23\u0d4d\u0d1f\u0d46\u0d24\u0d4d\u0d24\u0d41\u0d15',JD:'JD',Welcome_Title:'\u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d24\u0d3f\u0d30\u0d1a\u0d4d\u0d1a\u0d3f\u0d32\u0d3f\u0d28\u0d4d\u0d31\u0d46 \u0d2d\u0d3e\u0d35\u0d3f \u0d38\u0d4d\u0d35\u0d3e\u0d17\u0d24\u0d02',Welcome_Desc:'\u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d7e \u0d35\u0d3f\u0d36\u0d26\u0d40\u0d15\u0d30\u0d3f\u0d1a\u0d4d\u0d1a\u0d41\u0d15\u0d4a\u0d23\u0d4d\u0d1f\u0d4d \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d2a\u0d4d\u0d30\u0d4a\u0d2b\u0d48\u0d32\u0d41\u0d15\u0d7e \u0d0e\u0d15\u0d4d\u0d38\u0d4d\u0d2a\u0d4d\u0d32\u0d4b\u0d7c \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15. \u0d38\u0d4d\u0d15\u0d3f\u0d32\u0d4d\u0d32\u0d41\u0d15\u0d7e, \u0d31\u0d4b\u0d33\u0d41\u0d15\u0d7e, \u0d1c\u0d46\u0d7b\u0d21\u0d7c, \u0d0f\u0d1c\u0d4d \u0d17\u0d4d\u0d30\u0d42\u0d2a\u0d4d\u0d2a\u0d4d, \u0d38\u0d3f\u0d31\u0d4d\u0d31\u0d3f\u0d15\u0d7e \u0d05\u0d32\u0d4d\u0d32\u0d46\u0d19\u0d4d\u0d15\u0d3f\u0d7d \u0d2d\u0d3e\u0d37\u0d15\u0d7e \u0d09\u0d7e\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d3e\u0d7b \u0d36\u0d4d\u0d30\u0d2e\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d15.',Describe_Requirements:'\u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d06\u0d35\u0d36\u0d4d\u0d2f\u0d15\u0d24\u0d15\u0d7e \u0d35\u0d3f\u0d35\u0d30\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d15',Placeholder_Examples:{Example1:'\u0d0e\u0d28\u0d4d\u0d31\u0d46 \u0d38\u0d2e\u0d40\u0d2a\u0d24\u0d4d\u0d24\u0d4d 2 \u0d35\u0d7c\u0d37 \u0d05\u0d28\u0d41\u0d2d\u0d35\u0d2e\u0d41\u0d33\u0d4d\u0d33 \u0d2a\u0d4d\u0d30\u0d4a\u0d2b\u0d37\u0d23\u0d7d \u0d39\u0d57\u0d38\u0d4d\u0d15\u0d40\u0d2a\u0d4d\u0d2a\u0d7c',Example2:'2+ \u0d35\u0d7c\u0d37 \u0d05\u0d28\u0d41\u0d2d\u0d35\u0d2e\u0d41\u0d33\u0d4d\u0d33 25-30 \u0d35\u0d2f\u0d38\u0d4d\u0d38\u0d41\u0d33\u0d4d\u0d33 \u0d2b\u0d40\u0d2e\u0d46\u0d2f\u0d3f\u0d7d \u0d2c\u0d47\u0d2c\u0d3f\u0d38\u0d3f\u0d31\u0d4d\u0d31\u0d7c',Example3:'\u0d2c\u0d46\u0d02\u0d17\u0d33\u0d42\u0d30\u0d3f\u0d32\u0d46 \u0d05\u0d28\u0d41\u0d2d\u0d35\u0d38\u0d2e\u0d4d\u0d2a\u0d28\u0d4d\u0d28\u0d28\u0d3e\u0d2f \u0d2e\u0d46\u0d2f\u0d3f\u0d7d \u0d21\u0d4d\u0d30\u0d48\u0d35\u0d7c',Example4:'\u0d38\u0d57\u0d24\u0d4d\u0d24\u0d4d \u0d07\u0d28\u0d4d\u0d24\u0d4d\u0d2f\u0d7b \u0d15\u0d41\u0d38\u0d40\u0d7b \u0d0e\u0d15\u0d4d\u0d38\u0d4d\u0d2a\u0d46\u0d7c\u0d1f\u0d4d\u0d1f\u0d48\u0d38\u0d41\u0d33\u0d4d\u0d33 \u0d38\u0d40\u0d28\u0d3f\u0d2f\u0d7c \u0d37\u0d46\u0d2b\u0d4d',Example5:'\u0d0e\u0d28\u0d4d\u0d31\u0d46 \u0d38\u0d2e\u0d40\u0d2a\u0d24\u0d4d\u0d24\u0d46 \u0d21\u0d4b\u0d17\u0d4d \u0d35\u0d3e\u0d15\u0d4d\u0d15\u0d7c',Example6:'\u0d28\u0d4b\u0d7c\u0d24\u0d4d\u0d24\u0d4d & \u0d38\u0d57\u0d24\u0d4d\u0d24\u0d4d \u0d07\u0d28\u0d4d\u0d24\u0d4d\u0d2f\u0d7b \u0d15\u0d41\u0d38\u0d40\u0d7b \u0d0e\u0d15\u0d4d\u0d38\u0d4d\u0d2a\u0d46\u0d7c\u0d1f\u0d4d\u0d1f\u0d48\u0d38\u0d41\u0d33\u0d4d\u0d33 \u0d37\u0d46\u0d2b\u0d4d'},Find_Staff:'\u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d15\u0d23\u0d4d\u0d1f\u0d46\u0d24\u0d4d\u0d24\u0d41\u0d15'},NotificationsActivities:{title:'\u0d28\u0d4b\u0d1f\u0d4d\u0d1f\u0d3f\u0d2b\u0d3f\u0d15\u0d4d\u0d15\u0d47\u0d37\u0d28\u0d41\u0d15\u0d7e & \u0d06\u0d15\u0d4d\u0d1f\u0d3f\u0d35\u0d3f\u0d31\u0d4d\u0d31\u0d3f\u0d15\u0d7e',Approved_Leave:'\u0d05\u0d2a\u0d4d\u0d30\u0d42\u0d35\u0d4d\u0d21\u0d4d \u0d32\u0d40\u0d35\u0d4d',New_Staff_Onboarded:'\u0d2a\u0d41\u0d24\u0d3f\u0d2f \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d2e\u0d46\u0d2e\u0d4d\u0d2a\u0d7c \u0d13\u0d7a\u0d2c\u0d4b\u0d7c\u0d21\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d24\u0d41',Salary_Processed:'\u0d38\u0d3e\u0d32\u0d31\u0d3f \u0d2a\u0d4d\u0d30\u0d4b\u0d38\u0d38\u0d4d\u0d21\u0d4d',Time_Just_Now:'\u0d07\u0d2a\u0d4d\u0d2a\u0d4b\u0d7e \u0d24\u0d28\u0d4d\u0d28\u0d46',Time_Minutes_Ago:'\u0d2e\u0d3f\u0d28\u0d3f\u0d31\u0d4d\u0d31\u0d4d \u0d2e\u0d41\u0d2e\u0d4d\u0d2a\u0d4d',Time_Hour_Ago:'\u0d2e\u0d23\u0d3f\u0d15\u0d4d\u0d15\u0d42\u0d7c \u0d2e\u0d41\u0d2e\u0d4d\u0d2a\u0d4d',Time_Yesterday:'\u0d07\u0d28\u0d4d\u0d28\u0d32\u0d46'},AddStaff:{title:'\u0d2a\u0d41\u0d24\u0d3f\u0d2f \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d1a\u0d47\u0d7c\u0d15\u0d4d\u0d15\u0d41\u0d15',Enter_Staff_Aadhaar:'\u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d06\u0d27\u0d3e\u0d7c \u0d28\u0d7d\u0d15\u0d41\u0d15',Aadhaar_Number:'\u0d06\u0d27\u0d3e\u0d7c \u0d28\u0d2e\u0d4d\u0d2a\u0d7c',Aadhaar_Placeholder:'12-\u0d21\u0d3f\u0d1c\u0d3f\u0d31\u0d4d\u0d31\u0d4d \u0d06\u0d27\u0d3e\u0d7c \u0d28\u0d2e\u0d4d\u0d2a\u0d7c \u0d28\u0d7d\u0d15\u0d41\u0d15',Submit:'\u0d38\u0d2c\u0d4d\u0d2e\u0d3f\u0d31\u0d4d\u0d31\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',Verify:'OTP\u0d2f\u0d4b\u0d1f\u0d4a\u0d2a\u0d4d\u0d2a\u0d02 \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d06\u0d27\u0d3e\u0d7c \u0d35\u0d46\u0d30\u0d3f\u0d2b\u0d48 \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',Description:'\u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d06\u0d27\u0d3e\u0d7c XXXX-XXXX- \u0d2f\u0d41\u0d2e\u0d3e\u0d2f\u0d3f \u0d32\u0d3f\u0d19\u0d4d\u0d15\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d24 \u0d2e\u0d4a\u0d2c\u0d48\u0d7d \u0d28\u0d2e\u0d4d\u0d2a\u0d31\u0d3f\u0d32\u0d47\u0d15\u0d4d\u0d15\u0d4d \u0d12\u0d30\u0d41 OTP \u0d05\u0d2f\u0d1a\u0d4d\u0d1a\u0d41',OTP_Placeholders:'6-\u0d21\u0d3f\u0d1c\u0d3f\u0d31\u0d4d\u0d31\u0d4d OTP \u0d28\u0d7d\u0d15\u0d41\u0d15',Resend_Text:'OTP \u0d32\u0d2d\u0d3f\u0d1a\u0d4d\u0d1a\u0d3f\u0d32\u0d4d\u0d32\u0d47? \u0d35\u0d40\u0d23\u0d4d\u0d1f\u0d41\u0d02 \u0d05\u0d2f\u0d2f\u0d4d\u0d15\u0d4d\u0d15\u0d41\u0d15',Verify_Add_Staff:'\u0d35\u0d46\u0d30\u0d3f\u0d2b\u0d48 \u0d1a\u0d46\u0d2f\u0d4d\u0d24\u0d4d \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d2b\u0d4d \u0d1a\u0d47\u0d7c\u0d15\u0d4d\u0d15\u0d41\u0d15',Aadhaar_Info:'\u0d10\u0d21\u0d28\u0d4d\u0d31\u0d3f\u0d31\u0d4d\u0d31\u0d3f \u0d35\u0d46\u0d30\u0d3f\u0d2b\u0d3f\u0d15\u0d4d\u0d15\u0d47\u0d37\u0d28\u0d41\u0d02 \u0d2b\u0d4d\u0d30\u0d4b\u0d21\u0d4d \u0d32\u0d3f\u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3f\u0d19\u0d4d\u0d19\u0d41\u0d15\u0d7e \u0d24\u0d1f\u0d2f\u0d3e\u0d28\u0d41\u0d02 \u0d06\u0d27\u0d3e\u0d7c \u0d09\u0d2a\u0d2f\u0d4b\u0d17\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41, \u0d38\u0d39\u0d3e\u0d2f\u0d4d\u0d2f \u0d15\u0d2e\u0d4d\u0d2e\u0d4d\u0d2f\u0d42\u0d23\u0d3f\u0d31\u0d4d\u0d31\u0d