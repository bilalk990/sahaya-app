2\u0c4d \u0c05\u0c21\u0c4d\u0c30\u0c38\u0c4d',phone:'\u0c35\u0c3e\u0c1f\u0c4d\u0c38\u0c3e\u0c2a\u0c4d \u0c28\u0c02\u0c2c\u0c30\u0c4d',select_country:'\u0c26\u0c47\u0c36\u0c3e\u0c28\u0c4d\u0c28\u0c3f \u0c0e\u0c02\u0c1a\u0c41\u0c15\u0c4b\u0c02\u0c21\u0c3f',select_state:'\u0c30\u0c3e\u0c37\u0c4d\u0c1f\u0c4d\u0c30\u0c3e\u0c28\u0c4d\u0c28\u0c3f \u0c0e\u0c02\u0c1a\u0c41\u0c15\u0c4b\u0c02\u0c21\u0c3f',language:'\u0c2d\u0c3e\u0c37\u0c28\u0c41 \u0c0e\u0c02\u0c1a\u0c41\u0c15\u0c4b\u0c02\u0c21\u0c3f',notify:'\u0c28\u0c4b\u0c1f\u0c3f\u0c2b\u0c48 \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f',update:'\u0c2a\u0c4d\u0c30\u0c4a\u0c2b\u0c48\u0c32\u0c4d\u200c\u0c28\u0c41 \u0c05\u0c2a\u0c4d\u200c\u0c21\u0c47\u0c1f\u0c4d \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f',Preferences:'\u0c2a\u0c4d\u0c30\u0c3f\u0c2b\u0c30\u0c46\u0c28\u0c4d\u0c38\u0c46\u0c38\u0c4d',Name:'\u0c2a\u0c47\u0c30\u0c41'},Settings:{title:'\u0c38\u0c46\u0c1f\u0c4d\u0c1f\u0c3f\u0c02\u0c17\u0c4d\u0c38\u0c4d',alluse:'\u0c2e\u0c40 \u0c05\u0c28\u0c4d\u0c28\u0c3f \u0c2e\u0c41\u0c16\u0c4d\u0c2f\u0c2e\u0c48\u0c28 \u0c24\u0c47\u0c26\u0c40\u0c32\u0c41, \u0c28\u0c4b\u0c1f\u0c3f\u0c2b\u0c3f\u0c15\u0c47\u0c37\u0c28\u0c4d\u0c32\u0c41 & \u0c30\u0c3f\u0c2e\u0c48\u0c02\u0c21\u0c30\u0c4d\u0c32\u0c41',notif:'\u0c05\u0c28\u0c4d\u0c28\u0c3f \u0c24\u0c3e\u0c1c\u0c3e \u0c2f\u0c3e\u0c15\u0c4d\u0c1f\u0c3f\u0c35\u0c3f\u0c1f\u0c40\u0c32\u0c24\u0c4b \u0c24\u0c15\u0c4d\u0c37\u0c23 \u0c05\u0c2a\u0c4d\u200c\u0c21\u0c47\u0c1f\u0c4d\u200c\u0c32\u0c41 \u0c2a\u0c4a\u0c02\u0c26\u0c02\u0c21\u0c3f',reminders:'\u0c30\u0c3f\u0c2e\u0c48\u0c02\u0c21\u0c30\u0c4d\u0c32\u0c41',remindersSubtitle:'\u0c2e\u0c41\u0c39\u0c42\u0c30\u0c4d\u0c24\u0c3e\u0c32\u0c41 \u0c2e\u0c30\u0c3f\u0c2f\u0c41 \u0c08\u0c35\u0c46\u0c02\u0c1f\u0c4d \u0c30\u0c3f\u0c2e\u0c48\u0c02\u0c21\u0c30\u0c4d\u0c32\u0c41',helpu:'\u0c2e\u0c40\u0c15\u0c41 \u0c05\u0c35\u0c38\u0c30\u0c2e\u0c48\u0c28 \u0c38\u0c39\u0c3e\u0c2f\u0c3e\u0c28\u0c4d\u0c28\u0c3f \u0c2a\u0c4a\u0c02\u0c26\u0c02\u0c21\u0c3f, \u0c2e\u0c40\u0c15\u0c41 \u0c05\u0c35\u0c38\u0c30\u0c2e\u0c48\u0c28\u0c2a\u0c4d\u0c2a\u0c41\u0c21\u0c41',notifications:'\u0c28\u0c4b\u0c1f\u0c3f\u0c2b\u0c3f\u0c15\u0c47\u0c37\u0c28\u0c4d\u0c32\u0c41',notificationsSubtitle:'\u0c2a\u0c41\u0c37\u0c4d \u0c28\u0c4b\u0c1f\u0c3f\u0c2b\u0c3f\u0c15\u0c47\u0c37\u0c28\u0c4d\u200c\u0c28\u0c41 \u0c15\u0c38\u0c4d\u0c1f\u0c2e\u0c48\u0c1c\u0c4d \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f',whatsapp:'\u0c35\u0c3e\u0c1f\u0c4d\u0c38\u0c3e\u0c2a\u0c4d\u200c\u0c32\u0c4b \u0c2e\u0c3e\u0c15\u0c41 \u0c2e\u0c46\u0c38\u0c47\u0c1c\u0c4d \u0c2a\u0c02\u0c2a\u0c02\u0c21\u0c3f',about:'\u0c05\u0c2a\u0c4d \u0c17\u0c41\u0c30\u0c3f\u0c02\u0c1a\u0c3f',aboutSubtitle:'\u0c30\u0c3f\u0c2e\u0c48\u0c02\u0c21\u0c4d\u200c\u0c28\u0c4c \u0c05\u0c2a\u0c4d \u0c35\u0c3f\u0c35\u0c30\u0c3e\u0c32\u0c41',help:'\u0c39\u0c46\u0c32\u0c4d\u0c2a\u0c4d & \u0c38\u0c2a\u0c4b\u0c30\u0c4d\u0c1f\u0c4d',helpSubtitle:'\u0c38\u0c2a\u0c4b\u0c30\u0c4d\u0c1f\u0c4d \u0c05\u0c35\u0c38\u0c30\u0c2e\u0c3e? \u0c38\u0c41\u0c32\u0c2d\u0c02\u0c17\u0c3e \u0c38\u0c02\u0c2a\u0c4d\u0c30\u0c26\u0c3f\u0c02\u0c1a\u0c02\u0c21\u0c3f',delete:'\u0c2e\u0c40 \u0c05\u0c15\u0c4c\u0c02\u0c1f\u0c4d\u200c\u0c28\u0c41 \u0c21\u0c3f\u0c32\u0c40\u0c1f\u0c4d \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f',deleteSubtitle:'\u0c2e\u0c40\u0c30\u0c41 \u0c35\u0c46\u0c33\u0c4d\u0c24\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c28\u0c3f \u0c2e\u0c3e\u0c15\u0c41 \u0c2c\u0c3e\u0c27\u0c17\u0c3e \u0c09\u0c02\u0c26\u0c3f.',faq:'\u0c24\u0c30\u0c1a\u0c41\u0c17\u0c3e \u0c05\u0c21\u0c3f\u0c17\u0c47 \u0c2a\u0c4d\u0c30\u0c36\u0c4d\u0c28\u0c32\u0c41',faqSubtitle:'\u0c2e\u0c40\u0c15\u0c41 \u0c24\u0c46\u0c32\u0c41\u0c38\u0c41\u0c15\u0c4b\u0c35\u0c3e\u0c32\u0c4d\u0c38\u0c3f\u0c28 \u0c05\u0c28\u0c4d\u0c28\u0c40',logout:'\u0c32\u0c3e\u0c17\u0c4c\u0c1f\u0c4d',accountDeleteTitle:'\u0c05\u0c15\u0c4c\u0c02\u0c1f\u0c4d \u0c21\u0c3f\u0c32\u0c40\u0c1f\u0c4d',accountDeleteSubtitle:'\u0c2e\u0c40\u0c30\u0c41 \u0c35\u0c46\u0c33\u0c4d\u0c24\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c28\u0c3f \u0c2e\u0c3e\u0c15\u0c41 \u0c2c\u0c3e\u0c27\u0c17\u0c3e \u0c09\u0c02\u0c26\u0c3f.',accountDeleteDesc:'\u0c2e\u0c40 \u0c05\u0c15\u0c4c\u0c02\u0c1f\u0c4d\u200c\u0c28\u0c41 \u0c21\u0c3f\u0c32\u0c40\u0c1f\u0c4d \u0c1a\u0c47\u0c2f\u0c21\u0c02 \u0c38\u0c4d\u0c25\u0c3f\u0c30\u0c02\u0c17\u0c3e \u0c09\u0c02\u0c1f\u0c41\u0c02\u0c26\u0c3f. \u0c2e\u0c40 \u0c05\u0c28\u0c4d\u0c28\u0c3f \u0c21\u0c47\u0c1f\u0c3e, \u0c2c\u0c41\u0c15\u0c3f\u0c02\u0c17\u0c4d\u0c38\u0c4d, \u0c2e\u0c46\u0c38\u0c47\u0c1c\u0c4d\u200c\u0c32\u0c41 \u0c2e\u0c30\u0c3f\u0c2f\u0c41 \u0c2b\u0c4b\u0c1f\u0c4b\u0c32\u0c41 \u0c24\u0c4a\u0c32\u0c17\u0c3f\u0c02\u0c1a\u0c2c\u0c21\u0c24\u0c3e\u0c2f\u0c3f. \u0c08 \u0c1a\u0c30\u0c4d\u0c2f\u0c28\u0c41 \u0c24\u0c3f\u0c30\u0c3f\u0c17\u0c3f \u0c1a\u0c47\u0c2f\u0c32\u0c47\u0c2e\u0c41.',reasonPlaceholder:'\u0c08 \u0c05\u0c2a\u0c4d \u0c28\u0c3e\u0c15\u0c41 \u0c09\u0c2a\u0c2f\u0c4b\u0c17\u0c15\u0c30\u0c02\u0c17\u0c3e \u0c32\u0c47\u0c26\u0c41',reasonPrivacy:'\u0c28\u0c3e\u0c15\u0c41 \u0c2a\u0c4d\u0c30\u0c48\u0c35\u0c38\u0c40 \u0c06\u0c02\u0c26\u0c4b\u0c33\u0c28\u0c32\u0c41 \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c2f\u0c3f',reasonTooManyNotifications:'\u0c28\u0c47\u0c28\u0c41 \u0c1a\u0c3e\u0c32\u0c3e \u0c28\u0c4b\u0c1f\u0c3f\u0c2b\u0c3f\u0c15\u0c47\u0c37\u0c28\u0c4d\u0c32\u0c41 \u0c2a\u0c4a\u0c02\u0c26\u0c41\u0c24\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c28\u0c41',reasonDuplicate:'\u0c28\u0c47\u0c28\u0c41 \u0c21\u0c42\u0c2a\u0c4d\u0c32\u0c3f\u0c15\u0c47\u0c1f\u0c4d \u0c05\u0c15\u0c4c\u0c02\u0c1f\u0c4d\u200c\u0c28\u0c41 \u0c15\u0c4d\u0c30\u0c3f\u0c2f\u0c47\u0c1f\u0c4d \u0c1a\u0c47\u0c36\u0c3e\u0c28\u0c41',reasonOther:'\u0c07\u0c24\u0c30\u0c3e\u0c32\u0c41',reasonOtherPlaceholder:'\u0c0e\u0c02\u0c1f\u0c30\u0c4d \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f',deleteButton:'\u0c05\u0c15\u0c4c\u0c02\u0c1f\u0c4d\u200c\u0c28\u0c41 \u0c21\u0c3f\u0c32\u0c40\u0c1f\u0c4d \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f',cancelButton:'\u0c15\u0c4d\u0c2f\u0c3e\u0c28\u0c4d\u0c38\u0c32\u0c4d \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f',confirmTitle:'\u0c2e\u0c40\u0c30\u0c41 \u0c16\u0c1a\u0c4d\u0c1a\u0c3f\u0c24\u0c02\u0c17\u0c3e \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c30\u0c3e?',confirmDesc:'\u0c08 \u0c1a\u0c30\u0c4d\u0c2f \u0c38\u0c4d\u0c25\u0c3f\u0c30\u0c02\u0c17\u0c3e \u0c09\u0c02\u0c1f\u0c41\u0c02\u0c26\u0c3f. \u0c2e\u0c40 \u0c05\u0c28\u0c4d\u0c28\u0c3f \u0c21\u0c47\u0c1f\u0c3e \u0c24\u0c4a\u0c32\u0c17\u0c3f\u0c02\u0c1a\u0c2c\u0c21\u0c41\u0c24\u0c41\u0c02\u0c26\u0c3f.',confirmCancel:'\u0c32\u0c47\u0c26\u0c41, \u0c28\u0c3e \u0c05\u0c15\u0c4c\u0c02\u0c1f\u0c4d\u200c\u0c28\u0c41 \u0c09\u0c02\u0c1a\u0c02\u0c21\u0c3f',confirmDelete:'\u0c05\u0c35\u0c41\u0c28\u0c41, \u0c21\u0c3f\u0c32\u0c40\u0c1f\u0c4d \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f',suport_title:'\u0c2a\u0c4d\u0c30\u0c36\u0c4d\u0c28\u0c32\u0c41 \u0c32\u0c47\u0c26\u0c3e \u0c2b\u0c40\u0c21\u0c4d\u200c\u0c2c\u0c4d\u0c2f\u0c3e\u0c15\u0c4d \u0c09\u0c02\u0c26\u0c3e?',suport_subtitle:'\u0c2e\u0c40\u0c15\u0c41 \u0c0f\u0c26\u0c48\u0c28\u0c3e \u0c2a\u0c4d\u0c30\u0c36\u0c4d\u0c28\u0c32\u0c41, \u0c2b\u0c40\u0c21\u0c4d\u200c\u0c2c\u0c4d\u0c2f\u0c3e\u0c15\u0c4d \u0c32\u0c47\u0c26\u0c3e \u0c2e\u0c3e\u0c15\u0c41 \u0c2e\u0c46\u0c30\u0c41\u0c17\u0c41\u0c2a\u0c21\u0c1f\u0c3e\u0c28\u0c3f\u0c15\u0c3f \u0c38\u0c1c\u0c46\u0c37\u0c28\u0c4d\u0c32\u0c41 \u0c09\u0c02\u0c1f\u0c47, \u0c38\u0c02\u0c2a\u0c4d\u0c30\u0c26\u0c3f\u0c02\u0c1a\u0c21\u0c3e\u0c28\u0c3f\u0c15\u0c3f \u0c27\u0c48\u0c30\u0c4d\u0c2f\u0c2a\u0c21\u0c02\u0c21\u0c3f. \u0c2e\u0c40 \u0c06\u0c32\u0c4b\u0c1a\u0c28\u0c32\u0c28\u0c41 \u0c2e\u0c47\u0c2e\u0c41 \u0c17\u0c4c\u0c30\u0c35\u0c3f\u0c38\u0c4d\u0c24\u0c3e\u0c2e\u0c41 \u0c2e\u0c30\u0c3f\u0c2f\u0c41 \u0c30\u0c3f\u0c2e\u0c48\u0c02\u0c21\u0c4d\u200c\u0c28\u0c4c\u0c28\u0c41 \u0c2e\u0c40\u0c15\u0c41 \u0c0e\u0c32\u0c3e \u0c2e\u0c46\u0c30\u0c41\u0c17\u0c41\u0c2a\u0c30\u0c1a\u0c35\u0c1a\u0c4d\u0c1a\u0c4b \u0c24\u0c46\u0c32\u0c41\u0c38\u0c41\u0c15\u0c4b\u0c35\u0c3e\u0c32\u0c28\u0c3f \u0c15\u0c4b\u0c30\u0c41\u0c15\u0c41\u0c02\u0c1f\u0c3e\u0c2e\u0c41. \u0c2e\u0c3e\u0c15\u0c41 \u0c12\u0c15 \u