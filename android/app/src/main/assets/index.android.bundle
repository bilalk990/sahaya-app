\u0ccd',Verification:'\u0caa\u0cb0\u0cbf\u0cb6\u0cc0\u0cb2\u0ca8\u0cc6',Gender:'\u0cb2\u0cbf\u0c82\u0c97',Age_Range:'\u0c86\u0caf\u0cc1 \u0cb5\u0ccd\u0caf\u0cbe\u0caa\u0ccd\u0ca4\u0cbf',Expected_Salary:'\u0c8e\u0ca6\u0cc1\u0cb0\u0cbe\u0ca6 \u0cb8\u0c82\u0cac\u0cb3',Reset_Filters:'\u0cab\u0cbf\u0cb2\u0ccd\u0c9f\u0cb0\u0ccd\u200c\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0cae\u0cb0\u0cc1\u0cb8\u0ccd\u0ca5\u0cbe\u0caa\u0cbf\u0cb8\u0cbf',Apply_Filters:'\u0cab\u0cbf\u0cb2\u0ccd\u0c9f\u0cb0\u0ccd\u200c\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0c85\u0ca8\u0ccd\u0cb5\u0caf\u0cbf\u0cb8\u0cbf',Matching_Candidates:'\u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0caa\u0ccd\u0cb0\u0ca6\u0cc7\u0cb6\u0ca6\u0cb2\u0ccd\u0cb2\u0cbf \u0cb9\u0cca\u0c82\u0ca6\u0cbf\u0c95\u0cca\u0cb3\u0ccd\u0cb3\u0cc1\u0cb5 \u0c85\u0cad\u0ccd\u0caf\u0cb0\u0ccd\u0ca5\u0cbf\u0c97\u0cb3\u0cc1',Contact:'\u0cb8\u0c82\u0caa\u0cb0\u0ccd\u0c95',Police_Verification:'\u0caa\u0cca\u0cb2\u0cc0\u0cb8\u0ccd \u0caa\u0cb0\u0cbf\u0cb6\u0cc0\u0cb2\u0ca8\u0cc6',Verified:'\u0caa\u0cb0\u0cbf\u0cb6\u0cc0\u0cb2\u0cbf\u0ca4',Unverified:'\u0caa\u0cb0\u0cbf\u0cb6\u0cc0\u0cb2\u0cbf\u0ca4\u0cb5\u0cb2\u0ccd\u0cb2'},FindStaffAI:{title:'AI \u0c9c\u0cca\u0ca4\u0cc6\u0c97\u0cc6 \u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0c85\u0ca8\u0ccd\u0ca8\u0cc1 \u0c95\u0c82\u0ca1\u0cc1\u0cb9\u0cbf\u0ca1\u0cbf\u0caf\u0cbf',JD:'JD',Welcome_Title:'\u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0cb9\u0cc1\u0ca1\u0cc1\u0c95\u0cbe\u0c9f\u0ca6 \u0cad\u0cb5\u0cbf\u0cb7\u0ccd\u0caf\u0c95\u0ccd\u0c95\u0cc6 \u0cb8\u0ccd\u0cb5\u0cbe\u0c97\u0ca4',Welcome_Desc:'\u0ca8\u0cc0\u0cb5\u0cc1 \u0cac\u0caf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb5\u0cbf\u0cb5\u0cb0\u0cbf\u0cb8\u0cc1\u0cb5 \u0cae\u0cc2\u0cb2\u0c95 \u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0caa\u0ccd\u0cb0\u0cca\u0cab\u0cc8\u0cb2\u0ccd\u200c\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0c85\u0ca8\u0ccd\u0cb5\u0cc7\u0cb7\u0cbf\u0cb8\u0cbf. \u0c95\u0ccc\u0cb6\u0cb2\u0ccd\u0caf\u0c97\u0cb3\u0cc1, \u0caa\u0cbe\u0ca4\u0ccd\u0cb0\u0c97\u0cb3\u0cc1, \u0cb2\u0cbf\u0c82\u0c97, \u0c86\u0caf\u0cc1 \u0c97\u0cc1\u0c82\u0caa\u0cc1, \u0ca8\u0c97\u0cb0\u0c97\u0cb3\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0cad\u0cbe\u0cb7\u0cc6\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb8\u0cc7\u0cb0\u0cbf\u0cb8\u0cb2\u0cc1 \u0caa\u0ccd\u0cb0\u0caf\u0ca4\u0ccd\u0ca8\u0cbf\u0cb8\u0cbf.',Describe_Requirements:'\u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0c85\u0c97\u0ca4\u0ccd\u0caf\u0ca4\u0cc6\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb5\u0cbf\u0cb5\u0cb0\u0cbf\u0cb8\u0cbf',Placeholder_Examples:{Example1:'\u0ca8\u0ca8\u0ccd\u0ca8 \u0cac\u0cb3\u0cbf 2 \u0cb5\u0cb0\u0ccd\u0cb7\u0c97\u0cb3 \u0c85\u0ca8\u0cc1\u0cad\u0cb5\u0ca6\u0cca\u0c82\u0ca6\u0cbf\u0c97\u0cc6 \u0cb5\u0cc3\u0ca4\u0ccd\u0ca4\u0cbf\u0caa\u0cb0 \u0cb9\u0ccc\u0cb8\u0ccd\u200c\u0c95\u0cc0\u0caa\u0cb0\u0ccd',Example2:'25-30 \u0cb5\u0cb0\u0ccd\u0cb7\u0c97\u0cb3 2+ \u0cb5\u0cb0\u0ccd\u0cb7\u0c97\u0cb3 \u0c85\u0ca8\u0cc1\u0cad\u0cb5\u0ca6\u0cca\u0c82\u0ca6\u0cbf\u0c97\u0cc6 \u0cae\u0cb9\u0cbf\u0cb3\u0cbe \u0cac\u0cc7\u0cac\u0cbf\u0cb8\u0cbf\u0c9f\u0cb0\u0ccd',Example3:'\u0cac\u0cc6\u0c82\u0c97\u0cb3\u0cc2\u0cb0\u0cbf\u0ca8\u0cb2\u0ccd\u0cb2\u0cbf \u0c85\u0ca8\u0cc1\u0cad\u0cb5\u0c9c\u0ccd\u0c9e\u0ca8\u0cbe\u0ca6 \u0caa\u0cc1\u0cb0\u0cc1\u0cb7 \u0ca1\u0ccd\u0cb0\u0cc8\u0cb5\u0cb0\u0ccd',Example4:'\u0ca6\u0c95\u0ccd\u0cb7\u0cbf\u0ca3 \u0cad\u0cbe\u0cb0\u0ca4\u0cc0\u0caf \u0cb5\u0ccd\u0caf\u0c82\u0c9c\u0ca8 \u0c95\u0cc1\u0cb6\u0cb2\u0ca4\u0cc6\u0caf\u0cca\u0c82\u0ca6\u0cbf\u0c97\u0cc6 \u0cb8\u0cc0\u0ca8\u0cbf\u0caf\u0cb0\u0ccd \u0cb6\u0cc6\u0cab\u0ccd',Example5:'\u0ca8\u0ca8\u0ccd\u0ca8 \u0cac\u0cb3\u0cbf \u0ca1\u0cbe\u0c97\u0ccd \u0cb5\u0cbe\u0c95\u0cb0\u0ccd',Example6:'\u0c89\u0ca4\u0ccd\u0ca4\u0cb0 & \u0ca6\u0c95\u0ccd\u0cb7\u0cbf\u0ca3 \u0cad\u0cbe\u0cb0\u0ca4\u0cc0\u0caf \u0cb5\u0ccd\u0caf\u0c82\u0c9c\u0ca8 \u0c95\u0cc1\u0cb6\u0cb2\u0ca4\u0cc6\u0caf\u0cca\u0c82\u0ca6\u0cbf\u0c97\u0cc6 \u0cb6\u0cc6\u0cab\u0ccd'},Find_Staff:'\u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0c85\u0ca8\u0ccd\u0ca8\u0cc1 \u0c95\u0c82\u0ca1\u0cc1\u0cb9\u0cbf\u0ca1\u0cbf\u0caf\u0cbf'},NotificationsActivities:{title:'\u0c85\u0ca7\u0cbf\u0cb8\u0cc2\u0c9a\u0ca8\u0cc6\u0c97\u0cb3\u0cc1 & \u0c9a\u0c9f\u0cc1\u0cb5\u0c9f\u0cbf\u0c95\u0cc6\u0c97\u0cb3\u0cc1',Approved_Leave:'\u0c85\u0ca8\u0cc1\u0cae\u0ccb\u0ca6\u0cbf\u0ca4 \u0cb9\u0cbe\u0cab\u0ccd',New_Staff_Onboarded:'\u0cb9\u0cca\u0cb8 \u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0cb8\u0ca6\u0cb8\u0ccd\u0caf \u0c86\u0ca8\u0ccd\u200c\u0cac\u0ccb\u0cb0\u0ccd\u0ca1\u0ccd \u0c86\u0c97\u0cbf\u0ca6\u0cc6',Salary_Processed:'\u0cb8\u0c82\u0cac\u0cb3 \u0caa\u0ccd\u0cb0\u0cbe\u0cb8\u0cc6\u0cb8\u0ccd \u0c86\u0c97\u0cbf\u0ca6\u0cc6',Time_Just_Now:'\u0c88\u0c97\u0cb2\u0cc6',Time_Minutes_Ago:'\u0ca8\u0cbf\u0cae\u0cbf\u0cb7\u0c97\u0cb3 \u0cb9\u0cbf\u0c82\u0ca6\u0cc6',Time_Hour_Ago:'\u0c97\u0c82\u0c9f\u0cc6\u0c97\u0cb3 \u0cb9\u0cbf\u0c82\u0ca6\u0cc6',Time_Yesterday:'\u0ca8\u0cbf\u0ca8\u0ccd\u0ca8\u0cc6'},AddStaff:{title:'\u0cb9\u0cca\u0cb8 \u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0c85\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb8\u0cc7\u0cb0\u0cbf\u0cb8\u0cbf',Enter_Staff_Aadhaar:'\u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0c86\u0ca7\u0cbe\u0cb0\u0ccd \u0ca8\u0cae\u0cc2\u0ca6\u0cbf\u0cb8\u0cbf',Aadhaar_Number:'\u0c86\u0ca7\u0cbe\u0cb0\u0ccd \u0cb8\u0c82\u0c96\u0ccd\u0caf\u0cc6',Aadhaar_Placeholder:'12-\u0c85\u0c82\u0c95\u0ca6 \u0c86\u0ca7\u0cbe\u0cb0\u0ccd \u0cb8\u0c82\u0c96\u0ccd\u0caf\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cae\u0cc2\u0ca6\u0cbf\u0cb8\u0cbf',Submit:'\u0cb8\u0cb2\u0ccd\u0cb2\u0cbf\u0cb8\u0cbf',Verify:'OTP \u0c9c\u0cca\u0ca4\u0cc6\u0c97\u0cc6 \u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0c86\u0ca7\u0cbe\u0cb0\u0ccd \u0c85\u0ca8\u0ccd\u0ca8\u0cc1 \u0caa\u0cb0\u0cbf\u0cb6\u0cc0\u0cb2\u0cbf\u0cb8\u0cbf',Description:'\u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0c86\u0ca7\u0cbe\u0cb0\u0ccd XXXX-XXXX-  \u0c9c\u0cca\u0ca4\u0cc6\u0c97\u0cc6 \u0cb2\u0cbf\u0c82\u0c95\u0ccd \u0c86\u0c97\u0cbf\u0cb0\u0cc1\u0cb5 \u0cae\u0cca\u0cac\u0cc8\u0cb2\u0ccd \u0cb8\u0c82\u0c96\u0ccd\u0caf\u0cc6\u0c97\u0cc6 OTP \u0c95\u0cb3\u0cc1\u0cb9\u0cbf\u0cb8\u0cb2\u0cbe\u0c97\u0cbf\u0ca6\u0cc6',OTP_Placeholders:'6-\u0c85\u0c82\u0c95\u0ca6 OTP \u0ca8\u0cae\u0cc2\u0ca6\u0cbf\u0cb8\u0cbf',Resend_Text:'OTP \u0cac\u0c82\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2\u0cb5\u0cc7? \u0cae\u0ca4\u0ccd\u0ca4\u0cc6 \u0c95\u0cb3\u0cc1\u0cb9\u0cbf\u0cb8\u0cbf',Verify_Add_Staff:'\u0caa\u0cb0\u0cbf\u0cb6\u0cc0\u0cb2\u0cbf\u0cb8\u0cbf & \u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0c85\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb8\u0cc7\u0cb0\u0cbf\u0cb8\u0cbf',Aadhaar_Info:'\u0ca8\u0cbe\u0cb5\u0cc1 \u0c97\u0cc1\u0cb0\u0cc1\u0ca4\u0cc1 \u0caa\u0cb0\u0cbf\u0cb6\u0cc0\u0cb2\u0ca8\u0cc6 \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0cb5\u0c82\u0c9a\u0ca8\u0cc6\u0caf \u0caa\u0c9f\u0ccd\u0c9f\u0cbf\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca4\u0ca1\u0cc6\u0caf\u0cb2\u0cc1 \u0c86\u0ca7\u0cbe\u0cb0\u0ccd \u0c85\u0ca8\u0ccd\u0ca8\u0cc1 \u0cac\u0cb3\u0cb8\u0cc1\u0ca4\u0ccd\u0ca4\u0cc7\u0cb5\u0cc6, \u0cb8\u0cb9\u0cbe\u0caf\u0cbe \u0cb8\u0cae\u0cc1\u0ca6\u0cbe\u0caf\u0ca6\u0cb2\u0ccd\u0cb2\u0cbf \u0ca8\u0c82\u0cac\u0cbf\u0c95\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb9\u0cc6\u0c9a\u0ccd\u0c9a\u0cbf\u0cb8\u0cc1\u0ca4\u0ccd\u0ca4\u0cc7\u0cb5\u0cc6.'},AddStaffPhoto:{title:'\u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd\u200c\u0ca8 \u0c87\u0ca4\u0ccd\u0ca4\u0cc0\u0c9a\u0cbf\u0ca8 \u0c9a\u0cbf\u0ca4\u0ccd\u0cb0\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb8\u0cc7\u0cb0\u0cbf\u0cb8\u0cbf',Staff_Photo:'\u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0cab\u0ccb\u0c9f\u0ccb',Upload:'\u0c85\u0caa\u0ccd\u200c\u0cb2\u0ccb\u0ca1\u0ccd \u0cae\u0cbe\u0ca1\u0cbf'},NewStaffForm:{title:'\u0cb9\u0cca\u0cb8 \u0cb8\u0ccd\u0c9f\u0cbe\u0cab\u0ccd \u0cab\u0cbe\u0cb0\u0ccd\u0cae\u0ccd',Personal_Details:'\u0cb5\u0cc8\u0caf\u0c95\u0ccd\u0ca4\u0cbf\u0c95 \u0cb5\u0cbf\u0cb5\u0cb0\u0c97\u0cb3\u0cc1',Full_Name:'\u0caa\u0cc2\u0cb0\u0ccd\u0ca3 \u0cb9\u0cc6\u0cb8\u0cb0\u0cc1',Mobile_Number:'\u0cae\u0cca\u0cac\u0cc8\u0cb2\u0ccd \u0cb8\u0c82\u0c96\u0ccd\u0caf\u0cc6',Mobile_Placeholder:'\u0c89\u0ca6\u0cbe.