36\u0d19\u0d4d\u0d19\u0d7e, \u0d2b\u0d4b\u0d1f\u0d4d\u0d1f\u0d4b\u0d15\u0d7e \u0d0e\u0d32\u0d4d\u0d32\u0d3e\u0d02 \u0d2e\u0d3e\u0d2f\u0d4d\u0d15\u0d4d\u0d15\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d02. \u0d08 \u0d06\u0d15\u0d4d\u0d37\u0d7b \u0d24\u0d3f\u0d30\u0d3f\u0d1a\u0d4d\u0d1a\u0d41\u0d15\u0d1f\u0d15\u0d4d\u0d15\u0d3e\u0d28\u0d3e\u0d35\u0d3f\u0d32\u0d4d\u0d32.',reasonPlaceholder:'\u0d08 \u0d06\u0d2a\u0d4d\u0d2a\u0d4d \u0d0e\u0d28\u0d4d\u0d28\u0d4b\u0d1f\u0d4d \u0d09\u0d2a\u0d2f\u0d4b\u0d17\u0d2a\u0d4d\u0d30\u0d26\u0d2e\u0d32\u0d4d\u0d32',reasonPrivacy:'\u0d0e\u0d28\u0d3f\u0d15\u0d4d\u0d15\u0d4d \u0d38\u0d4d\u0d35\u0d15\u0d3e\u0d30\u0d4d\u0d2f\u0d24\u0d3e \u0d06\u0d36\u0d19\u0d4d\u0d15\u0d15\u0d7e \u0d09\u0d23\u0d4d\u0d1f\u0d4d',reasonTooManyNotifications:'\u0d0e\u0d28\u0d3f\u0d15\u0d4d\u0d15\u0d4d \u0d35\u0d33\u0d30\u0d46 \u0d15\u0d42\u0d1f\u0d41\u0d24\u0d7d \u0d28\u0d4b\u0d1f\u0d4d\u0d1f\u0d3f\u0d2b\u0d3f\u0d15\u0d4d\u0d15\u0d47\u0d37\u0d28\u0d41\u0d15\u0d7e \u0d15\u0d3f\u0d1f\u0d4d\u0d1f\u0d41\u0d28\u0d4d\u0d28\u0d41',reasonDuplicate:'\u0d1e\u0d3e\u0d7b \u0d12\u0d30\u0d41 \u0d21\u0d4d\u0d2f\u0d42\u0d2a\u0d4d\u0d32\u0d3f\u0d15\u0d4d\u0d15\u0d47\u0d31\u0d4d\u0d31\u0d4d \u0d05\u0d15\u0d4d\u0d15\u0d57\u0d23\u0d4d\u0d1f\u0d4d \u0d38\u0d43\u0d37\u0d4d\u0d1f\u0d3f\u0d1a\u0d4d\u0d1a\u0d41',reasonOther:'\u0d2e\u0d31\u0d4d\u0d31\u0d41\u0d33\u0d4d\u0d33\u0d35',reasonOtherPlaceholder:'\u0d0e\u0d28\u0d4d\u0d31\u0d7c \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',deleteButton:'\u0d05\u0d15\u0d4d\u0d15\u0d57\u0d23\u0d4d\u0d1f\u0d4d \u0d21\u0d3f\u0d32\u0d40\u0d31\u0d4d\u0d31\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',cancelButton:'\u0d31\u0d26\u0d4d\u0d26\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',confirmTitle:'\u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d7e \u0d09\u0d31\u0d2a\u0d4d\u0d2a\u0d3e\u0d23\u0d4b?',confirmDesc:'\u0d08 \u0d06\u0d15\u0d4d\u0d37\u0d7b \u0d38\u0d4d\u0d25\u0d3f\u0d30\u0d2e\u0d3e\u0d23\u0d4d. \u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d0e\u0d32\u0d4d\u0d32\u0d3e \u0d21\u0d3e\u0d31\u0d4d\u0d31\u0d2f\u0d41\u0d02 \u0d21\u0d3f\u0d32\u0d40\u0d31\u0d4d\u0d31\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d02.',confirmCancel:'\u0d07\u0d32\u0d4d\u0d32, \u0d0e\u0d28\u0d4d\u0d31\u0d46 \u0d05\u0d15\u0d4d\u0d15\u0d57\u0d23\u0d4d\u0d1f\u0d4d \u0d28\u0d3f\u0d32\u0d28\u0d3f\u0d7c\u0d24\u0d4d\u0d24\u0d41\u0d15',confirmDelete:'\u0d05\u0d24\u0d46, \u0d21\u0d3f\u0d32\u0d40\u0d31\u0d4d\u0d31\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',suport_title:'\u0d1a\u0d4b\u0d26\u0d4d\u0d2f\u0d19\u0d4d\u0d19\u0d33\u0d4b \u0d2b\u0d40\u0d21\u0d4d\u0d2c\u0d3e\u0d15\u0d4d\u0d15\u0d4b \u0d09\u0d23\u0d4d\u0d1f\u0d4b?',suport_subtitle:'\u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d7e\u0d15\u0d4d\u0d15\u0d4d \u0d0f\u0d24\u0d46\u0d19\u0d4d\u0d15\u0d3f\u0d32\u0d41\u0d02 \u0d1a\u0d4b\u0d26\u0d4d\u0d2f\u0d19\u0d4d\u0d19\u0d7e, \u0d2b\u0d40\u0d21\u0d4d\u0d2c\u0d3e\u0d15\u0d4d\u0d15\u0d4d, \u0d05\u0d32\u0d4d\u0d32\u0d46\u0d19\u0d4d\u0d15\u0d3f\u0d7d \u0d1e\u0d19\u0d4d\u0d19\u0d33\u0d46 \u0d2e\u0d46\u0d1a\u0d4d\u0d1a\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d3e\u0d7b \u0d38\u0d39\u0d3e\u0d2f\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28 \u0d28\u0d3f\u0d7c\u0d26\u0d47\u0d36\u0d19\u0d4d\u0d19\u0d7e \u0d09\u0d23\u0d4d\u0d1f\u0d46\u0d19\u0d4d\u0d15\u0d3f\u0d7d, \u0d26\u0d2f\u0d35\u0d3e\u0d2f\u0d3f \u0d38\u0d02\u0d36\u0d2f\u0d3f\u0d15\u0d4d\u0d15\u0d3e\u0d24\u0d46 \u0d31\u0d40\u0d1a\u0d4d\u0d1a\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15. \u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d1a\u0d3f\u0d28\u0d4d\u0d24\u0d15\u0d33\u0d46 \u0d1e\u0d19\u0d4d\u0d19\u0d7e \u0d2f\u0d25\u0d3e\u0d7c\u0d24\u0d4d\u0d25\u0d24\u0d4d\u0d24\u0d3f\u0d7d \u0d35\u0d3f\u0d32\u0d2e\u0d24\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41, \u0d31\u0d3f\u0d2e\u0d48\u0d7b\u0d21\u0d4d\u0d28\u0d57\u0d35\u0d3f\u0d28\u0d46 \u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d7e\u0d15\u0d4d\u0d15\u0d4d \u0d35\u0d47\u0d23\u0d4d\u0d1f\u0d3f \u0d0e\u0d19\u0d4d\u0d19\u0d28\u0d46 \u0d2e\u0d46\u0d1a\u0d4d\u0d1a\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d3e\u0d02 \u0d0e\u0d28\u0d4d\u0d28\u0d4d \u0d05\u0d31\u0d3f\u0d2f\u0d3e\u0d7b \u0d06\u0d17\u0d4d\u0d30\u0d39\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41. \u0d12\u0d30\u0d41 \u0d07\u0d2e\u0d46\u0d2f\u0d3f\u0d7d \u0d05\u0d2f\u0d2f\u0d4d\u0d15\u0d4d\u0d15\u0d41\u0d15 \u2014 \u0d1e\u0d19\u0d4d\u0d19\u0d7e \u0d0e\u0d2a\u0d4d\u0d2a\u0d4b\u0d34\u0d41\u0d02 \u0d15\u0d47\u0d7e\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41.'},DeleteAccount:{title:'\u0d05\u0d15\u0d4d\u0d15\u0d57\u0d23\u0d4d\u0d1f\u0d4d \u0d21\u0d3f\u0d32\u0d40\u0d31\u0d4d\u0d31\u0d4d',subtitle:'\u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d7e \u0d2a\u0d4b\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d4d \u0d15\u0d3e\u0d23\u0d3e\u0d7b \u0d1e\u0d19\u0d4d\u0d19\u0d7e\u0d15\u0d4d\u0d15\u0d4d \u0d35\u0d3f\u0d37\u0d2e\u0d2e\u0d3e\u0d23\u0d4d.',reason_label:'\u0d2a\u0d4b\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d3f\u0d28\u0d4d\u0d31\u0d46 \u0d15\u0d3e\u0d30\u0d23\u0d02',placeholder:'\u0d0e\u0d28\u0d4d\u0d31\u0d7c \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',delete_btn:'\u0d05\u0d15\u0d4d\u0d15\u0d57\u0d23\u0d4d\u0d1f\u0d4d \u0d21\u0d3f\u0d32\u0d40\u0d31\u0d4d\u0d31\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',cancel_btn:'\u0d31\u0d26\u0d4d\u0d26\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15',confirm_title:'\u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d7e \u0d09\u0d31\u0d2a\u0d4d\u0d2a\u0d3e\u0d23\u0d4b?',confirm_desc:'\u0d08 \u0d06\u0d15\u0d4d\u0d37\u0d7b \u0d38\u0d4d\u0d25\u0d3f\u0d30\u0d2e\u0d3e\u0d23\u0d4d. \u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d0e\u0d32\u0d4d\u0d32\u0d3e \u0d21\u0d3e\u0d31\u0d4d\u0d31\u0d2f\u0d41\u0d02 \u0d21\u0d3f\u0d32\u0d40\u0d31\u0d4d\u0d31\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d02.',keep_account:'\u0d07\u0d32\u0d4d\u0d32, \u0d0e\u0d28\u0d4d\u0d31\u0d46 \u0d05\u0d15\u0d4d\u0d15\u0d57\u0d23\u0d4d\u0d1f\u0d4d \u0d28\u0d3f\u0d32\u0d28\u0d3f\