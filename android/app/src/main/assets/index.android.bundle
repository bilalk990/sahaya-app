\u0c32\u0c4d\u0c1f\u0c30\u0c4d\u0c38\u0c4d\u200c\u0c28\u0c41 \u0c30\u0c40\u0c38\u0c46\u0c1f\u0c4d \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f',Apply_Filters:'\u0c2b\u0c3f\u0c32\u0c4d\u0c1f\u0c30\u0c4d\u0c38\u0c4d\u200c\u0c28\u0c41 \u0c05\u0c2a\u0c4d\u0c32\u0c48 \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f',Matching_Candidates:'\u0c2e\u0c40 \u0c0f\u0c30\u0c3f\u0c2f\u0c3e\u0c32\u0c4b \u0c2e\u0c4d\u0c2f\u0c3e\u0c1a\u0c3f\u0c02\u0c17\u0c4d \u0c15\u0c4d\u0c2f\u0c3e\u0c02\u0c21\u0c3f\u0c21\u0c47\u0c1f\u0c4d\u0c38\u0c4d',Contact:'\u0c15\u0c3e\u0c02\u0c1f\u0c3e\u0c15\u0c4d\u0c1f\u0c4d',Police_Verification:'\u0c2a\u0c4b\u0c32\u0c40\u0c38\u0c4d \u0c35\u0c46\u0c30\u0c3f\u0c2b\u0c3f\u0c15\u0c47\u0c37\u0c28\u0c4d',Verified:'\u0c35\u0c46\u0c30\u0c3f\u0c2b\u0c48\u0c21\u0c4d',Unverified:'\u0c05\u0c28\u0c4d\u200c\u0c35\u0c46\u0c30\u0c3f\u0c2b\u0c48\u0c21\u0c4d'},FindStaffAI:{title:'AI\u0c24\u0c4b \u0c38\u0c4d\u0c1f\u0c3e\u0c2b\u0c4d\u200c\u0c28\u0c41 \u0c15\u0c28\u0c41\u0c17\u0c4a\u0c28\u0c02\u0c21\u0c3f',JD:'JD',Welcome_Title:'\u0c38\u0c4d\u0c1f\u0c3e\u0c2b\u0c4d \u0c38\u0c46\u0c30\u0c4d\u0c1a\u0c4d \u0c2f\u0c4a\u0c15\u0c4d\u0c15 \u0c2d\u0c35\u0c3f\u0c37\u0c4d\u0c2f\u0c24\u0c4d\u0c24\u0c41\u0c15\u0c41 \u0c38\u0c4d\u0c35\u0c3e\u0c17\u0c24\u0c02',Welcome_Desc:'\u0c2e\u0c40\u0c30\u0c41 \u0c15\u0c4b\u0c30\u0c41\u0c15\u0c41\u0c28\u0c47\u0c26\u0c3e\u0c28\u0c4d\u0c28\u0c3f \u0c35\u0c3f\u0c35\u0c30\u0c3f\u0c02\u0c1a\u0c21\u0c02 \u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c3e \u0c38\u0c4d\u0c1f\u0c3e\u0c2b\u0c4d \u0c2a\u0c4d\u0c30\u0c4a\u0c2b\u0c48\u0c32\u0c4d\u0c38\u0c4d\u200c\u0c28\u0c41 \u0c0e\u0c15\u0c4d\u0c38\u0c4d\u200c\u0c2a\u0c4d\u0c32\u0c4b\u0c30\u0c4d \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f. \u0c38\u0c4d\u0c15\u0c3f\u0c32\u0c4d\u0c38\u0c4d, \u0c30\u0c4b\u0c32\u0c4d\u0c38\u0c4d, \u0c1c\u0c46\u0c02\u0c21\u0c30\u0c4d, \u0c0f\u0c1c\u0c4d \u0c17\u0c4d\u0c30\u0c42\u0c2a\u0c4d, \u0c38\u0c3f\u0c1f\u0c40\u0c38\u0c4d \u0c32\u0c47\u0c26\u0c3e \u0c32\u0c3e\u0c02\u0c17\u0c4d\u0c35\u0c47\u0c1c\u0c46\u0c38\u0c4d\u200c\u0c28\u0c41 \u0c1f\u0c4d\u0c30\u0c48 \u0c1a\u0c47\u0c2f\u0c02\u0c21\u0c3f.',Describe_Requirements:'\u0c38\u0c4d\u0c1f\u0c3e\u0c2b\u0c4d \u0c30\u0c3f\u0c15\u0c4d\u0c35\u0c48\u0c30\u0c4d\u200c\u0c2e\u0c46\u0c02\u0c1f\u0c4d\u0c38\u0c4d\u200c\u0c28\u0c41 \u0c35\u0c3f\u0c35\u0c30\u0c3f\u0c02\u0c1a\u0c02\u0c21\u0c3f',Placeholder_Examples:{Example1:'\u0c28\u0c3e \u0c38\u0c2e\u0c40\u0c2a\u0c02\u0c32\u0c4b 2 \u0c38\u0c02\u0c35\u0c24\u0c4d\u0c38\u0c30\u0c3e\u0c32 \u0c05\u0c28\u0c41\u0c2d\u0c35\u0c02 \u0c09\u0c28\u0c4d\u0c28 \u0c2a\u0c4d\u0c30\u0c4a\u0c2b\u0c46\u0c37\u0c28\u0c32\u0c4d \u0c39\u0c4c\u0c38\u0c4d\u200c\u0c15\u0c40\u0c2a\u0c30\u0c4d',Example2:'2+ \u0c38\u0c02\u0c35\u0c24\u0c4d\u0c38\u0c30\u0c3e\u0c32 \u0c05\u0c28\u0c41\u0c2d\u0c35\u0c02 \u0c09\u0c28\u0c4d\u0c28 25-30 \u0c38\u0c02\u0c35\u0c24\u0c4d\u0c38\u0c30\u0c3e\u0c32 \u0c2e\u0c39\u0c3f\u0c33\u0c3e \u0c2c\u0c47\u0c2c\u0c40\u0c38\u0c3f\u0c1f\u0c30\u0c4d',Example3:'\u0c2c\u0c46\u0c02\u0c17\u0c33\u0c42\u0c30\u0c41\u0c32\u0c4b \u0c05\u0c28\u0c41\u0c2d\u0c35\u0c1c\u0c4d\u0c1e\u0c41\u0c21\u0c48\u0c28 \u0c2e\u0c17 \u0c21\u0c4d\u0c30\u0c48\u0c35\u0c30\u0c4d',Example4:'\u0c38\u0c4c\u0c24\u0c4d \u0c07\u0c02\u0c21\u0c3f\u0c2f\u0c28\u0c4d \u0c15\u0c41\u0c38\u0c3f\u0c28\u0c4d \u0c0e\u0c15\u0c4d\u0c38\u0c4d\u200c\u0c2a\u0c30\u0c4d\u0c1f\u0c48\u0c1c\u0c4d \u0c09\u0c28\u0c4d\u0c28 \u0c38\u0c40\u0c28\u0c3f\u0c2f\u0c30\u0c4d \u0c1a\u0c46\u0c2b\u0c4d',Example5:'\u0c28\u0c3e \u0c38\u0c2e\u0c40\u0c2a\u0c02\u0c32\u0c4b \u0c21\u0c3e\u0c17\u0c4d \u0c35\u0c3e\u0c15\u0c30\u0c4d',Example6:'\u0c28\u0c3e\u0c30\u0c4d\u0c24\u0c4d & \u0c38\u0c4c\u0c24\u0c4d \u0c07\u0c02\u0c21\u0c3f\u0c2f\u0c28\u0c4d \u0c15\u0c41\u0c38\u0c3f\u0c28\u0c4d \u0c0e\u0c15\u0c4d\u0c38\u0c4d\u200c\u0c2a\u0c30\u0c4d\u0c1f\u0c48\u0c1c\u0c4d \u0c09\u0c28\u0c4d\u0c28 \u0c1a\u0c46\u0c2b\u0c4d'},Find_Staff:'\u0c38\u0c4d\u0c1f\u0c3e\u0c2b\u0c4d\u200c\u0c28\u0c41 \u0c15\u0c28\u0c41\u0c17\u0c4a\u0c28\u0c02\u0c21\u0c3f'},NotificationsActivities:{title:'\u0c28\u0c4b\u0c1f\u0c3f\u0c2b\