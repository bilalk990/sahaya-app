# Sahayya App Environment Configuration
# Copy this file to .env and update the values

# ===========================================
# MAIN BACKEND API
# ===========================================
# Production URL
API_BASE_URL=http://sahayya.co.in/public/api/

# Local Development URL (uncomment when developing locally)
# API_BASE_URL=http://localhost:8000/api/

# ===========================================
# RAZORPAY PAYMENT GATEWAY
# ===========================================
# Razorpay Payment API Base URL (PHP Backend)
RAZORPAY_API_URL=http://localhost:8000/api/

# Test Mode Keys (Replace with your own test keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Production Keys (Replace with live keys for production)
# RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXX
# RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ===========================================
# GOOGLE MAPS
# ===========================================
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ===========================================
# ANALYTICS (Optional)
# ===========================================
MIXPANEL_KEY=

# ===========================================
# APP SETTINGS
# ===========================================
APP_ENV=development
# APP_ENV=production
